# ===================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==================================================================
# Copy this file to .env.production.local and fill in production values
# NOTE: Never commit .env.production.local to version control
# ===================================================================

# ==================================================================
# Core Application Settings
# ==================================================================
NODE_ENV=production
PORT=3000
APP_NAME=School ERP System
APP_VERSION=v1.0.0

# ==================================================================
# Firebase Configuration (Production Project)
# ==================================================================
FIREBASE_PROJECT_ID=school-erp-prod
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=school-erp-prod.firebaseapp.com
FIREBASE_DATABASE_URL=https://school-erp-prod.firebaseio.com
FIREBASE_STORAGE_BUCKET=school-erp-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Firebase Admin SDK (Server-side only)
FIREBASE_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE_BASE64_ENCODED
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@school-erp-prod.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=YOUR_CLIENT_ID_HERE

# ==================================================================
# Database Configuration
# ==================================================================
STORAGE_DRIVER=firestore
FIRESTORE_MAX_RETRIES=5
FIRESTORE_BATCH_SIZE=100
FIRESTORE_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT=15000

# ==================================================================
# Authentication & Authorization
# ==================================================================
AUTH_MODE=firebase
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE_MIN_32_CHARS
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
SESSION_TIMEOUT_MINUTES=1440
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=Strict

# ==================================================================
# API Configuration
# ==================================================================
API_HOST=https://api.school-erp.com
API_VERSION=v1
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=15m
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=https://school-erp.com,https://www.school-erp.com

# ==================================================================
# Logging & Monitoring
# ==================================================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_ERROR_TRACKING=true

# Google Cloud Logging
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_LOG_NAME=school-erp-api
CLOUD_LOGGING_ENABLED=true

# ==================================================================
# Application Insights / Monitoring
# ==================================================================
MONITORING_ENABLED=true
METRICS_COLLECTION_ENABLED=true
TRACE_SAMPLING_RATE=0.1
ERROR_REPORTING_ENABLED=true

# Sentry (Error Tracking)
SENTRY_DSN=YOUR_SENTRY_DSN_URL
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1

# ==================================================================
# Analytics
# ==================================================================
ANALYTICS_ENABLED=true
BIGQUERY_PROJECT_ID=school-erp-prod
BIGQUERY_DATASET_ID=analytics
ANALYTICS_TRACKING_ID=YOUR_GOOGLE_ANALYTICS_ID
SESSION_ANALYTICS_ENABLED=true

# ==================================================================
# Email Configuration (Optional)
# ==================================================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@school-erp.com
SENDGRID_FROM_NAME=School ERP System

# Alternative: AWS SES
# EMAIL_PROVIDER=aws-ses
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# ==================================================================
# AWS Configuration (If using AWS services)
# ==================================================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=school-erp-prod-uploads
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
AWS_CDN_DOMAIN=cdn.school-erp.com

# ==================================================================
# File Storage Configuration
# ==================================================================
FILE_UPLOAD_MAX_SIZE=52428800  # 50MB in bytes
FILE_UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xlsx,xls,jpg,jpeg,png,csv
FILE_STORAGE_BACKEND=firestore
STORAGE_RETENTION_DAYS=365

# ==================================================================
# Security Configuration
# ==================================================================
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MINUTES=30

# OWASP CSP Headers
CSP_ENABLED=true
CSP_REPORTONLY=false

# ==================================================================
# Feature Flags
# ==================================================================
FEATURE_OFFLINE_MODE=false
FEATURE_ADVANCED_REPORTING=true
FEATURE_BULK_OPERATIONS=true
FEATURE_API_RATE_LIMITING=true
FEATURE_REQUEST_VALIDATION=true
FEATURE_AUDIT_LOGGING=true

# ==================================================================
# Business Rules
# ==================================================================
SCHOOL_ACADEMIC_YEAR_START=04-01
SCHOOL_ACADEMIC_YEAR_END=03-31
EXAM_MARKS_DECIMAL_PLACES=2
EXAM_PASS_PERCENTAGE=40
ATTENDANCE_MARKING_CUTOFF_TIME=16:30

# ==================================================================
# Webhook Configuration
# ==================================================================
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# ==================================================================
# Cache Configuration
# ==================================================================
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# ==================================================================
# Deployment Platform Specific
# ==================================================================

# For Google Cloud Run
GCP_RUN_REGION=asia-south1
GCP_RUN_MEMORY=1Gi
GCP_RUN_CPU=1
GCP_RUN_TIMEOUT=3600
GCP_RUN_CONCURRENCY=100

# For Vercel
VERCEL_ENV=production
VERCEL_URL=https://school-erp.vercel.app
VERCEL_ANALYTICS_ID=YOUR_VERCEL_ANALYTICS_ID

# For AWS Lambda
LAMBDA_TIMEOUT=30
LAMBDA_MEMORY=1024
LAMBDA_EPHEMERAL_STORAGE=512

# ==================================================================
# Third-party Integrations (Optional)
# ==================================================================

# Slack Integration
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK
SLACK_NOTIFICATIONS_ENABLED=false

# Teams Integration
TEAMS_WEBHOOK_URL=YOUR_TEAMS_WEBHOOK
TEAMS_NOTIFICATIONS_ENABLED=false

# Payment Gateway (if applicable)
PAYMENT_GATEWAY=stripe
STRIPE_PUBLIC_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ==================================================================
# Audit & Compliance
# ==================================================================
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=1825  # 5 years
DATA_RETENTION_POLICY=gdpr
GDPR_COMPLIANCE_MODE=true
PII_MASKING_ENABLED=true

# ==================================================================
# Performance Tuning
# ==================================================================
DB_CONNECTION_POOL_SIZE=20
API_QUERY_TIMEOUT_MS=30000
API_MAX_PAYLOAD_SIZE=10mb
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# ==================================================================
# Backup & Disaster Recovery
# ==================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=90
BACKUP_STORAGE=gcs
GCS_BACKUP_BUCKET=school-erp-backups-prod

# ==================================================================
# Version & Build Information (Auto-filled)
# ==================================================================
# These should be set by your CI/CD pipeline
BUILD_NUMBER=WILL_BE_SET_BY_CI_CD
BUILD_TIMESTAMP=WILL_BE_SET_BY_CI_CD
GIT_COMMIT_SHA=WILL_BE_SET_BY_CI_CD
GIT_BRANCH=main

# ==================================================================
# NOTES
# ==================================================================
# 1. Update all YOUR_* placeholders with actual values
# 2. Keep this file secure - never commit actual secrets
# 3. Use secret management (GCP Secret Manager, AWS Secrets Manager, etc.)
# 4. Rotate sensitive values regularly
# 5. Use different secrets for each environment (prod, staging, dev)
# 6. Test all settings in staging before production deployment
# ===================================================================
