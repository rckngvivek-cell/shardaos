rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Firestore security rules apply ONLY to Firebase client SDK access.
     * The School ERP API uses the Firebase Admin SDK and is not subject to these rules.
     *
     * Current baseline:
     * - Tenant data is stored under `/schools/{schoolId}/...`.
     * - Clients are expected to read/write via the API, not directly via Firestore.
     *
     * These rules are intentionally conservative: tenant-scoped READS only and no client WRITES.
     * If direct client access is introduced, relax these rules in a dedicated slice with tests.
     */

    function isAuthenticated() {
      return request.auth != null;
    }

    function tokenSchoolId() {
      // Support both camelCase and snake_case claims.
      return request.auth == null
        ? null
        : (request.auth.token.schoolId != null ? request.auth.token.schoolId : request.auth.token.school_id);
    }

    function isTenant() {
      return isAuthenticated() && tokenSchoolId() is string && tokenSchoolId().size() > 0;
    }

    function isTenantOf(schoolId) {
      return isTenant() && tokenSchoolId() == schoolId;
    }

    // ── Tenant plane: read-only within the caller's school ──
    match /schools/{schoolId} {
      allow get, list: if isTenantOf(schoolId);
      allow create, update, delete: if false;

      // Any subcollections under the school doc remain read-only for now.
      match /{document=**} {
        allow get, list: if isTenantOf(schoolId);
        allow create, update, delete: if false;
      }
    }

    // ── Platform plane: no direct client access in the current baseline ──
    match /platform_employees/{docId} {
      allow read, write: if false;
    }

    match /platform_approvals/{docId} {
      allow read, write: if false;
    }

    match /platform_audit_log/{docId} {
      allow read, write: if false;
    }

    // ── Default deny ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
