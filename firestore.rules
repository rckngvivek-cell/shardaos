rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==== UTILITY FUNCTIONS ====
    
    // Check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get current user doc from users collection
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user has specific role
    function hasRole(role) {
      return getUserDoc().role == role;
    }
    
    // Check if user is admin
    function isAdmin() {
      return hasRole('admin');
    }
    
    // Check if user is teacher
    function isTeacher() {
      return hasRole('teacher');
    }
    
    // Check if user is student
    function isStudent() {
      return hasRole('student');
    }
    
    // Check if user is parent
    function isParent() {
      return hasRole('parent');
    }
    
    // Check if user belongs to school
    function belongsToSchool(schoolId) {
      return getUserDoc().schoolId == schoolId;
    }
    
    // Check if this is the same user
    function isUser(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if parent owns child
    function parentOwnsChild(childId) {
      return childId in getUserDoc().childrenIds;
    }
    
    // ==== SCHOOLS COLLECTION ====
    
    match /schools/{schoolId} {
      // Authenticated users can read schools they belong to, or admins can read all
      allow read: if isAuthenticated() && (
        isAdmin() || belongsToSchool(schoolId)
      );
      
      // Only admins can create schools
      allow create: if isAuthenticated() && isAdmin();
      
      // Only admins can update schools
      allow update: if isAuthenticated() && isAdmin();
      
      // Only admins can delete schools
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== STUDENTS COLLECTION ====
    
    match /students/{studentId} {
      // Admin: can read all
      // Teacher: can read students from their school
      // Student: can only read themselves
      // Parent: can read their child
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isTeacher() && belongsToSchool(resource.data.schoolId)) ||
        (isStudent() && isUser(studentId)) ||
        (isParent() && parentOwnsChild(studentId))
      );
      
      // Only admins can create students
      allow create: if isAuthenticated() && isAdmin();
      
      // Only admins can update students
      allow update: if isAuthenticated() && isAdmin();
      
      // Only admins can delete students
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== TEACHERS COLLECTION ====
    
    match /teachers/{teacherId} {
      // Admin: can read all
      // Teachers: can only read themselves
      // Others: cannot read
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isTeacher() && isUser(teacherId))
      );
      
      // Only admins can create teachers
      allow create: if isAuthenticated() && isAdmin();
      
      // Admins can update all, teachers can update themselves
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isTeacher() && isUser(teacherId))
      );
      
      // Only admins can delete teachers
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== ATTENDANCE COLLECTION ====
    
    match /attendance/{attendanceId} {
      // Admin: can read all
      // Teacher: can read/write for their school
      // Student: can read own attendance
      // Parent: can read child's attendance
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isTeacher() && belongsToSchool(resource.data.schoolId)) ||
        (isStudent() && resource.data.studentId == request.auth.uid) ||
        (isParent() && parentOwnsChild(resource.data.studentId))
      );
      
      // Only admin and teacher (for own school) can create attendance
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (isTeacher() && belongsToSchool(request.resource.data.schoolId))
      );
      
      // Only admin and teacher (for own school) can update/delete
      allow update, delete: if isAuthenticated() && (
        isAdmin() || 
        (isTeacher() && belongsToSchool(resource.data.schoolId))
      );
    }
    
    // ==== GRADES COLLECTION ====
    
    match /grades/{gradeId} {
      // Admin: can read all
      // Teacher: can read grades for their school
      // Student: can read own grades
      // Parent: can read child's grades
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isTeacher() && belongsToSchool(resource.data.schoolId)) ||
        (isStudent() && resource.data.studentId == request.auth.uid) ||
        (isParent() && parentOwnsChild(resource.data.studentId))
      );
      
      // Only admin and teacher (for own school) can create grades
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (isTeacher() && belongsToSchool(request.resource.data.schoolId))
      );
      
      // Only admin and teacher (for own school) can update grades
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isTeacher() && belongsToSchool(resource.data.schoolId))
      );
      
      // Only admin can delete grades
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== ANNOUNCEMENTS COLLECTION ====
    
    match /announcements/{announcementId} {
      // All authenticated users can read announcements for their school
      // Admins can read all announcements
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.schoolId == null) || // Global announcements
        belongsToSchool(resource.data.schoolId)
      );
      
      // Only admins and teachers can create announcements
      allow create: if isAuthenticated() && (
        isAdmin() || isTeacher()
      );
      
      // Only admins can update/delete
      allow update, delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== USERS COLLECTION (Sensitive) ====
    
    match /users/{userId} {
      // Users can only read own data, or admin can read all
      allow read: if isAuthenticated() && (
        isUser(userId) || 
        isAdmin()
      );
      
      // Users can only update own data, or admin can update
      allow update: if isAuthenticated() && (
        isUser(userId) || 
        isAdmin()
      );
      
      // Only admin can create/delete users
      allow create: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==== DEFAULT DENY ====
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
