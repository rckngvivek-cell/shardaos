# Analytics Configuration for Week 4

# ============================================================================
# GOOGLE ANALYTICS 4 CONFIGURATION
# ============================================================================
# Get these credentials from https://analytics.google.com/

# Enable/disable GA4 integration
GA4_ENABLED=true

# Google Analytics Measurement ID (looks like G-XXXXXXXXXX)
# Found in: Admin > Data Streams > Web > Measurement ID
GA4_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID_HERE

# Google Analytics API Secret
# Found in: Admin > Data Streams > Web > Measurement Protocol > API Secrets
GA4_API_SECRET=YOUR_API_SECRET_HERE

# ============================================================================
# ANALYTICS SERVICE CONFIGURATION
# ============================================================================

# Enable/disable analytics service entirely
# Set to 'false' to disable all analytics logging
ANALYTICS_ENABLED=true

# Firestore collections for storing analytics events
ANALYTICS_EVENTS_COLLECTION=analytics_events
ANALYTICS_METRICS_COLLECTION=metrics

# Batch size for event buffering (before sending to backend)
ANALYTICS_BATCH_SIZE=100

# Flush interval in milliseconds (how often to send pending events)
ANALYTICS_FLUSH_INTERVAL_MS=5000

# ============================================================================
# APPLICATION VERSIONING
# ============================================================================

# Application version (used in analytics context)
APP_VERSION=0.1.0

# ============================================================================
# FIRESTORE CONFIGURATION
# ============================================================================

# Firestore database name (usually default)
FIRESTORE_DATABASE=(default)

# Local Firestore Emulator (for development)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Enable console logging of analytics events (development only)
# This is automatically enabled in development mode
NODE_ENV=development

# ============================================================================
# 📚 SETUP INSTRUCTIONS
# ============================================================================

# 1. Get Google Analytics 4 Credentials:
#    a. Go to https://analytics.google.com/
#    b. Create new property or select existing
#    c. In Admin section, go to "Data Streams"
#    d. Select your web stream
#    e. Copy Measurement ID (G-XXXXXXXXXX)
#    f. In Admin, scroll down to "Measurement Protocol API secrets"
#    g. Create new API secret and copy the value

# 2. Run locally:
#    npm run dev:api
#    npm run dev:web

# 3. Test analytics:
#    - Perform login action
#    - Check Firestore console for events in 'analytics_events' collection
#    - Check Google Analytics for events within 24 hours

# 4. For Firestore Emulator (local development):
#    - Install: npm install --save-dev firebase-tools
#    - Start: firebase emulators:start
#    - Set FIRESTORE_EMULATOR_HOST=localhost:8080 in .env
#    - Tests will use emulator automatically

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# If GA4 credentials are not working:
# 1. Verify Measurement ID matches your GA4 property
# 2. Check API Secret is enabled in GA4 Admin
# 3. GA4 can take 24 hours to show new events
# 4. Try test endpoint: POST /api/v1/telemetry/test (development only)

# If Firestore events not appearing:
# 1. Check Firestore is initialized properly
# 2. Verify security rules allow writes to 'analytics_events' collection
# 3. Check browser console for errors
# 4. Verify Express middleware is added before routes

# If events are missing:
# 1. Check ANALYTICS_ENABLED=true
# 2. Verify telemetry endpoint is reachable: POST /api/v1/telemetry
# 3. Check network tab in browser DevTools
# 4. Look for errors in Express server logs
