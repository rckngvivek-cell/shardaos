{
  "name": "@school-erp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup-bigquery": "tsx scripts/setup-bigquery.ts",
    "setup-dataflow": "tsx scripts/setup-dataflow.ts",
    "verify-pipeline": "tsx scripts/verify-pipeline.ts",
    "setup-gcp": "bash scripts/setup-gcp-infrastructure.sh"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.4",
    "@google-cloud/logging": "^10.5.0",
    "@google-cloud/pubsub": "^4.11.0",
    "csv-stringify": "^6.4.4",
    "exceljs": "^4.3.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^1.3.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.8",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pdfkit": "^0.12.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  }
}
