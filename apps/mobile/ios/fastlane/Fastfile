default_platform(:ios)

platform :ios do
  desc "Run iOS tests"
  lane :run_tests do
    scan(
      workspace: "SchoolERP.xcworkspace",
      scheme: "SchoolERP",
      code_coverage: true,
      output_directory: "build/coverage",
      devices: ["iPhone 14"],
      clean: true,
      configuration: "Debug"
    )
  end

  desc "Build iOS release for TestFlight"
  lane :build_release do
    # Ensure we have a clean build
    clear_derived_data
    
    # Update provisioning profiles
    update_code_signing_settings(
      use_automatic_signing: true,
      code_sign_identity: "iPhone Distribution"
    )

    # Build the app
    build_app(
      workspace: "SchoolERP.xcworkspace",
      scheme: "SchoolERP",
      configuration: "Release",
      output_directory: "build/ipa",
      output_name: "SchoolERP.ipa",
      derived_data_path: "build/derivedData",
      destination: "generic/platform=iOS",
      archive_path: "build/SchoolERP.xcarchive",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.schoolerp.mobile" => "SchoolERP Distribution"
        }
      },
      skip_package_ipa: false,
      skip_package_pkg: true,
      catalyst_platform: false,
      include_bitcode: false,
      include_symbols: true
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    # Prerequisites: set FASTLANE_USER and FASTLANE_PASSWORD
    # Or use app-specific password for better security
    
    upload_to_testflight(
      skip_submission: true,
      skip_waiting_for_build_processing: true,
      ipa: "build/ipa/SchoolERP.ipa",
      changelog: "Week 5: Mobile CI/CD Release - Automated TestFlight deployment via GitHub Actions",
      beta_app_review_info: {
        contact_email: "devops@schoolerp.app",
        contact_first_name: "DevOps",
        contact_last_name: "Team",
        contact_phone: "+91-XXXXXXXXXX",
        demo_account_name: "demo@schoolerp.app",
        demo_account_password: "DemoPass123!",
        notes: "Beta testing with School ERP pilot schools"
      },
      beta_app_feedback_email: "feedback@schoolerp.app",
      notify_external_testers: true,
      groups: ["SchoolERP Pilot Schools", "Internal Testing"]
    )
  end

  desc "Complete iOS build and upload pipeline"
  lane :ci_build do
    run_tests
    build_release
    upload_testflight
  end

  desc "Increment build number"
  lane :increment_build_number do
    increment_build_number(xcodeproj: "SchoolERP.xcodeproj")
  end

  desc "Increment version number"
  lane :increment_version_number do
    increment_version_number(
      xcodeproj: "SchoolERP.xcodeproj",
      bump_type: "patch"
    )
  end
end
