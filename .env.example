# Local development defaults
NODE_ENV=development
PORT=3000

# Current local API auth mode.
# - dev keeps the local tenant-header bypass enabled for fast UI work
# - jwt enforces first-party bearer-token verification
AUTH_MODE=dev

# Firebase/Firestore emulator values for local integration work.
FIREBASE_PROJECT_ID=school-erp-dev
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081

# Required for JWT-backed owner bootstrap or production API auth.
# Do not place bootstrap secrets in repo env files. Inject the bootstrap key
# through the process environment or point the API at a secret file path.
GOOGLE_APPLICATION_CREDENTIALS=
OWNER_BOOTSTRAP_KEY_CREDENTIAL_TARGET=
OWNER_BOOTSTRAP_KEY_FILE=
OWNER_BOOTSTRAP_SESSION_TTL_MIN=10
OWNER_BOOTSTRAP_API_BASE_URL=http://127.0.0.1:3000
OWNER_BOOTSTRAP_WEB_LOGIN_URL=http://127.0.0.1:5174/login
ADMIN_ALLOWED_IPS=
ADMIN_SESSION_TIMEOUT_MIN=15
ADMIN_MFA_REQUIRED=true
AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_MIN=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_MAX_RESENDS=3
AUTH_OTP_RESEND_COOLDOWN_SEC=45
# Local MailDev defaults. Replace these with your real SMTP provider in
# shared, staging, or production environments.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS_FILE=
SMTP_FROM_EMAIL=no-reply@shardaos.local
SMTP_FROM_NAME=ShardaOS Auth

# Portal build-time defaults used for non-sensitive local labels only.
VITE_DEV_EMPLOYEE_EMAIL=admin@dev.school
VITE_DEV_EMPLOYEE_ROLE=school_admin
VITE_DEV_EMPLOYEE_SCHOOL_ID=dev-school-001

# Owner portal display fallback only.
VITE_DEV_OWNER_EMAIL=owner@shardaos.com
VITE_DEV_OWNER_DISPLAY_NAME=Platform Owner
