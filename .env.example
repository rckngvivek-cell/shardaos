# Local development defaults
NODE_ENV=development
PORT=3000

# Current local API auth mode.
# - `dev` bypasses auth for tenant routes during local development
# - `firebase` enforces bearer-token verification
AUTH_MODE=dev

# Firebase emulator values for local integration work.
FIREBASE_PROJECT_ID=school-erp-dev
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Required only for real Firebase Admin credentials outside emulator mode.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
OWNER_BOOTSTRAP_KEY=

# Web app (Vite) local owner login fallback when Firebase web config is not set.
VITE_DEV_OWNER_EMAIL=owner@shardaos.com
VITE_DEV_OWNER_PASSWORD=Owner@12345
