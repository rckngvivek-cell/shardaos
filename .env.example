# Local development defaults
NODE_ENV=development
PORT=8080

# Current day-1 local mode: mock auth + in-memory storage.
AUTH_MODE=mock
STORAGE_DRIVER=memory

# Switch to these values when running against the Firebase emulator stack.
FIREBASE_PROJECT_ID=school-erp-dev
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Required only for real Firebase Admin credentials outside emulator mode.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
