# Environment Configuration Template
# Day 1: Development Environment Setup
# Author: DevOps Team
# Status: In Development

# ============================================================================
# BACKEND CONFIGURATION (.env file)
# ============================================================================

# Node Environment
NODE_ENV=development
PORT=3001

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Firebase/Firestore
GOOGLE_CLOUD_PROJECT=school-erp-dev
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
FIRESTORE_EMULATOR_HOST=localhost:8080  # For local development

# Firebase Database URL (alternative to Firestore)
FIREBASE_DATABASE_URL=https://school-erp-dev.firebaseio.com

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API Base URLs
API_URL=http://localhost:3001
API_BASE_PATH=/api/v1

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================================================
# FRONTEND CONFIGURATION (.env.local file for React)
# ============================================================================

# React Environment
REACT_APP_ENV=development
REACT_APP_API_URL=http://localhost:3001/api/v1
REACT_APP_ENV_NAME=development

# Firebase Config (for frontend)
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=school-erp-dev.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=school-erp-dev
REACT_APP_FIREBASE_STORAGE_BUCKET=school-erp-dev.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Logging Level
LOG_LEVEL=debug

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Email Service (future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Twilio (SMS - future use)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# SECURITY
# ============================================================================

# Password Hashing
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# Debug Mode
DEBUG=school-erp:*

# Request Logging
REQUEST_LOGGING_ENABLED=true

# ============================================================================
# INSTRUCTIONS
# ============================================================================

# 1. Backend Setup:
#    cp .env.example .env
#    Edit .env with your values
#    npm install
#    npm run dev

# 2. Frontend Setup:
#    cd frontend
#    cp .env.example .env.local
#    Edit .env.local with your values
#    npm install
#    npm start

# 3. Firestore Emulator (for local testing):
#    npm install -g firebase-tools
#    firebase emulators:start
#    Set FIRESTORE_EMULATOR_HOST in .env

# 4. To get Google Cloud credentials:
#    gcloud auth application-default login
#    Or download service account key from Google Cloud Console

# ============================================================================
# SECURE NOTES
# ============================================================================

# NEVER commit .env files with real secrets!
# NEVER use development secrets in production!
# Use Google Cloud Secret Manager for prod secrets
# Rotate JWT secrets monthly
# Use strong passwords for all services
