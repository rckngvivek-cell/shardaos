{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/dist/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "AUTH_MODE": "jwt"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}